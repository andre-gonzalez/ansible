# Allow xinit to access the virtual terminal it was started from
/dev/tty@{u8}   rw,

# Allow network socket creation needed for nameservice resolution (glibc NSS)
network netlink raw,
network inet    dgram,
network inet6   dgram,
network inet6   stream,
network inet    stream,

# Allow sh (running under xinit profile) to read the user's .xinitrc
owner @{HOME}/.xinitrc r,

# Allow executing programs installed to /usr/local/bin (e.g. dwm, dwmblocks, slock)
/usr/local/bin/*  rpux,
/usr/local/sbin/* rpux,

# Allow executing scripts from user home .scripts directory
owner @{HOME}/.scripts/  r,
owner @{HOME}/.scripts/** rpux,

# Allow reading wallpaper directory
owner @{HOME}/.config/.wallpaper/ r,
owner @{HOME}/.config/.wallpaper/** r,
